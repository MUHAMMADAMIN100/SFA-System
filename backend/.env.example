# Backend environment variables.
# Локально: скопируй в backend/.env (файл в .gitignore).
# На Railway: задай как Variables сервиса.

# Длинная случайная строка. Сгенерировать:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string

# True только локально. На Railway = False.
DEBUG=True

# Хосты, с которых принимаем запросы (через запятую). Домен Railway добавляется
# автоматически из RAILWAY_PUBLIC_DOMAIN — здесь его указывать не нужно.
ALLOWED_HOSTS=localhost,127.0.0.1

# Источники, которым доверяет CSRF (для входа в Django admin по HTTPS).
# Добавь сюда домен Vercel и домен Railway, напр.:
# https://sfa.vercel.app,https://sfa-system-production.up.railway.app
CSRF_TRUSTED_ORIGINS=

# Разрешённые origin для CORS (домен фронтенда на Vercel), через запятую.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# DATABASE_URL подставляет Railway Postgres автоматически (ссылка на сервис БД).
# Локально не задавай — будет использован SQLite.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Путь к смонтированному Railway Volume для фото накладных. Напр.: /app/media
# Локально не задавай — фото лягут в backend/media.
# MEDIA_ROOT=/app/media
